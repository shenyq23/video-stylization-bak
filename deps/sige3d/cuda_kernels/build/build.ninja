ninja_required_version = 1.3
cxx = c++
nvcc = /usr/local/cuda/bin/nvcc

cflags = -DTORCH_EXTENSION_NAME=sige3d_cuda_ext -DTORCH_API_INCLUDE_EXTENSION_H -DPYBIND11_COMPILER_TYPE=\"_gcc\" -DPYBIND11_STDLIB=\"_libstdcpp\" -DPYBIND11_BUILD_ABI=\"_cxxabi1011\" -I/media/cephfs/video/VideoUsers/thu2025/shenyiqing/video-stylization-bak/deps/sige3d/cuda_kernels -isystem /root/miniconda3/envs/stream/lib/python3.10/site-packages/torch/include -isystem /root/miniconda3/envs/stream/lib/python3.10/site-packages/torch/include/torch/csrc/api/include -isystem /root/miniconda3/envs/stream/lib/python3.10/site-packages/torch/include/TH -isystem /root/miniconda3/envs/stream/lib/python3.10/site-packages/torch/include/THC -isystem /usr/local/cuda/include -isystem /root/miniconda3/envs/stream/include/python3.10 -D_GLIBCXX_USE_CXX11_ABI=0 -fPIC -std=c++17 -O3
post_cflags = 
cuda_cflags = -DTORCH_EXTENSION_NAME=sige3d_cuda_ext -DTORCH_API_INCLUDE_EXTENSION_H -DPYBIND11_COMPILER_TYPE=\"_gcc\" -DPYBIND11_STDLIB=\"_libstdcpp\" -DPYBIND11_BUILD_ABI=\"_cxxabi1011\" -I/media/cephfs/video/VideoUsers/thu2025/shenyiqing/video-stylization-bak/deps/sige3d/cuda_kernels -isystem /root/miniconda3/envs/stream/lib/python3.10/site-packages/torch/include -isystem /root/miniconda3/envs/stream/lib/python3.10/site-packages/torch/include/torch/csrc/api/include -isystem /root/miniconda3/envs/stream/lib/python3.10/site-packages/torch/include/TH -isystem /root/miniconda3/envs/stream/lib/python3.10/site-packages/torch/include/THC -isystem /usr/local/cuda/include -isystem /root/miniconda3/envs/stream/include/python3.10 -D_GLIBCXX_USE_CXX11_ABI=0 -D__CUDA_NO_HALF_OPERATORS__ -D__CUDA_NO_HALF_CONVERSIONS__ -D__CUDA_NO_BFLOAT16_CONVERSIONS__ -D__CUDA_NO_HALF2_OPERATORS__ --expt-relaxed-constexpr -gencode=arch=compute_52,code=sm_52 -gencode=arch=compute_60,code=sm_60 -gencode=arch=compute_61,code=sm_61 -gencode=arch=compute_70,code=sm_70 -gencode=arch=compute_75,code=sm_75 -gencode=arch=compute_80,code=sm_80 -gencode=arch=compute_86,code=sm_86 -gencode=arch=compute_90,code=compute_90 -gencode=arch=compute_90,code=sm_90 --compiler-options '-fPIC' -O3 -std=c++17
cuda_post_cflags = 
cuda_dlink_post_cflags = 
ldflags = -shared -L/root/miniconda3/envs/stream/lib/python3.10/site-packages/torch/lib -lc10 -lc10_cuda -ltorch_cpu -ltorch_cuda -ltorch -ltorch_python -L/usr/local/cuda/lib64 -lcudart

rule compile
  command = $cxx -MMD -MF $out.d $cflags -c $in -o $out $post_cflags
  depfile = $out.d
  deps = gcc

rule cuda_compile
  depfile = $out.d
  deps = gcc
  command = $nvcc --generate-dependencies-with-compile --dependency-output $out.d $cuda_cflags -c $in -o $out $cuda_post_cflags



rule link
  command = $cxx $in $ldflags -o $out

build pybind_cuda.o: compile /media/cephfs/video/VideoUsers/thu2025/shenyiqing/video-stylization-bak/deps/sige3d/cuda_kernels/pybind_cuda.cpp
build gather2d.cuda.o: cuda_compile /media/cephfs/video/VideoUsers/thu2025/shenyiqing/video-stylization-bak/deps/sige3d/cuda_kernels/gather2d.cu
build scatter2d.cuda.o: cuda_compile /media/cephfs/video/VideoUsers/thu2025/shenyiqing/video-stylization-bak/deps/sige3d/cuda_kernels/scatter2d.cu
build gather3d.cuda.o: cuda_compile /media/cephfs/video/VideoUsers/thu2025/shenyiqing/video-stylization-bak/deps/sige3d/cuda_kernels/gather3d.cu
build scatter3d.cuda.o: cuda_compile /media/cephfs/video/VideoUsers/thu2025/shenyiqing/video-stylization-bak/deps/sige3d/cuda_kernels/scatter3d.cu
build scatter_gather3d.cuda.o: cuda_compile /media/cephfs/video/VideoUsers/thu2025/shenyiqing/video-stylization-bak/deps/sige3d/cuda_kernels/scatter_gather3d.cu



build sige3d_cuda_ext.so: link pybind_cuda.o gather2d.cuda.o scatter2d.cuda.o gather3d.cuda.o scatter3d.cuda.o scatter_gather3d.cuda.o

default sige3d_cuda_ext.so
